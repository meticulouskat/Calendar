        events: [
          ["3-7", "Mon-Fri", "yellow", "Teacher Appreciation Week"],
          ["5", "Wed", "orange", "May Day"],
          ["7", "Fri", "teal", "Community Potluck"],
          ["11", "Tue", "blue", "Community Council Meeting, 8:30 AM"],
          ["19", "Wed", "purple", "Board Meeting, 6:30 PM"],
          ["26", "Wed", "orange", "8th Grade Promotion"],
          ["27", "Thu", "yellow", "Senior Graduation; Early Release (Noon)"],
          ["28", "Fri", "orange", "Early Release (Noon); Rainbow Bridge; Last Day of School"]
        ]
      }
    ];

    const keyItems = [
      ["red", "Government Holiday / No School"],
      ["pink", "No School - Break"],
      ["purple", "Board Meeting, 6:30 PM"],
      ["blue", "Community Council Meeting, 8:30 AM"],
      ["teal", "Community Potluck / All Staff Meeting"],
      ["yellow", "Early Release (or Special Event)"],
      ["orange", "Special Events / Celebration"]
    ];

    const weekdays = ["S", "M", "T", "W", "T", "F", "S"];

    function dayPosition(year, month, day) {
      const first = new Date(year, month, 1).getDay();
      const index = first + day - 1;
      return {
        col: (index % 7) + 1,
        row: Math.floor(index / 7) + 2
      };
    }

    function renderMonth(monthData) {
      const card = document.createElement("article");
      card.className = "month-card";
      card.style.setProperty("--theme", colorHex[monthData.theme]);

      const title = document.createElement("h2");
      title.className = "month-title";
      title.textContent = monthData.title;
      card.appendChild(title);

      const body = document.createElement("div");
      body.className = "month-body";

      const grid = document.createElement("div");
      grid.className = "calendar-grid";
      grid.setAttribute("aria-label", monthData.title + " month grid");

      weekdays.forEach((day, index) => {
        const weekday = document.createElement("div");
        weekday.className = "weekday";
        weekday.style.gridColumn = index + 1;
        weekday.style.gridRow = 1;
        weekday.textContent = day;
        grid.appendChild(weekday);
      });

      monthData.ranges.forEach((range) => {
        const start = dayPosition(monthData.year, monthData.month, range.start);
        const end = dayPosition(monthData.year, monthData.month, range.end);
        if (start.row === end.row) {
          const strip = document.createElement("div");
          strip.className = "range-strip " + range.color;
          strip.style.gridColumn = start.col + " / " + (end.col + 1);
          strip.style.gridRow = start.row;
          grid.appendChild(strip);
        }
      });

      const rangeColors = {};
      monthData.ranges.forEach((range) => {
        for (let day = range.start; day <= range.end; day += 1) {
          rangeColors[day] = range.color;
        }
      });

      const daysInMonth = new Date(monthData.year, monthData.month + 1, 0).getDate();
      for (let day = 1; day <= daysInMonth; day += 1) {
        const pos = dayPosition(monthData.year, monthData.month, day);
        const cell = document.createElement("div");
        cell.className = "day-cell";
        cell.style.gridColumn = pos.col;
        cell.style.gridRow = pos.row;

        const number = document.createElement("span");
        const color = monthData.marks[day];
        const darkRangeColors = ["purple", "orange", "red", "blue", "teal", "green"];
        number.className = "day-num" + (color ? " marked " + color : "") + (darkRangeColors.includes(rangeColors[day]) && !color ? " on-dark-range" : "");
        number.textContent = day;
        cell.appendChild(number);
        grid.appendChild(cell);
      }

      body.appendChild(grid);

      const list = document.createElement("div");
      list.className = "events-list";
      monthData.events.forEach(([date, dow, color, text]) => {
        const row = document.createElement("div");
        row.className = "event-row";

        const badge = document.createElement("span");
        badge.className = "badge " + color;
        badge.textContent = date;

        const day = document.createElement("span");
        day.className = "dow";
        day.textContent = dow;

        const copy = document.createElement("span");
        copy.className = "event-text";
        copy.textContent = text;

        row.append(badge, day, copy);
        list.appendChild(row);
      });

      body.appendChild(list);
      card.appendChild(body);
      return card;
    }

    function renderKey() {
      const card = document.createElement("aside");
      card.className = "key-card";
      card.style.setProperty("--theme", colorHex.navy);

      const title = document.createElement("h2");
      title.className = "key-title";
      title.textContent = "KEY";
      card.appendChild(title);

      const body = document.createElement("div");
      body.className = "key-body";

      const list = document.createElement("div");
      list.className = "key-list";
      keyItems.forEach(([color, label]) => {
        const item = document.createElement("div");
        item.className = "key-item";

        const dot = document.createElement("span");
        dot.className = "key-dot " + color;

        const text = document.createElement("span");
        text.textContent = label;

        item.append(dot, text);
        list.appendChild(item);
      });

      const note = document.createElement("div");
      note.className = "note";
      note.innerHTML = '<span class="star" aria-hidden="true">★</span><span>All dates and times are subject to change. Please watch for updates and reminders.</span>';

      body.append(list, note);
      card.appendChild(body);
      return card;
    }

    const target = document.getElementById("calendarMonths");
    months.forEach((month) => target.appendChild(renderMonth(month)));
    target.appendChild(renderKey());
  </script>
</body>
</html>
