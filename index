        ranges: [],
        events: [
          ["4", "Fri", "teal", "Community Potluck & Clothing Exchange"],
          ["7", "Mon", "red", "Labor Day (No School)"],
          ["8", "Tue", "blue", "Community Council Meeting, 8:30 AM"],
          ["16", "Wed", "purple", "Board Meeting, 6:30 PM"],
          ["28", "Mon", "orange", "Michaelmas"]
        ]
      },
      {
        title: "OCTOBER 2026", year: 2026, month: 9, theme: "orange",
        marks: { 2: "teal", 5: "orange", 12: "red", 20: "blue", 21: "purple", 24: "orange", 30: "orange" },
        ranges: [
          { start: 7, end: 9, color: "yellow" },
          { start: 12, end: 16, color: "pink" }
        ],
        events: [
          ["2", "Fri", "teal", "Community Potluck"],
          ["5", "Mon", "orange", "40th Day (Tie-Dye Event)"],
          ["7-9", "Wed-Fri", "yellow", "Early Release (Noon)"],
          ["12-16", "Mon-Fri", "pink", "Fall Break (No School)"],
          ["12", "Mon", "red", "Indigenous People's Day"],
          ["20", "Tue", "blue", "Community Council Meeting, 8:30 AM"],
          ["21", "Wed", "purple", "Board Meeting, 6:30 PM"],
          ["24", "Sat", "orange", "Halloween Carnival"],
          ["30", "Fri", "orange", "Penny Faire"]
        ]
      },
      {
        title: "NOVEMBER 2026", year: 2026, month: 10, theme: "red",
        marks: { 6: "teal", 10: "blue", 11: "red", 18: "purple" },
        ranges: [{ start: 23, end: 27, color: "pink" }],
        events: [
          ["6", "Fri", "teal", "Community Potluck & Books/Board Games Exchange"],
          ["10", "Tue", "blue", "Martinmas (Lantern Walk); Community Council Meeting, 8:30 AM"],
          ["11", "Wed", "red", "Veterans Day (No School)"],
          ["18", "Wed", "purple", "Board Meeting, 6:30 PM"],
          ["23-27", "Mon-Fri", "pink", "Thanksgiving Break (No School)"]
        ]
      },
      {
        title: "DECEMBER 2026", year: 2026, month: 11, theme: "navy",
        marks: { 4: "teal", 8: "blue", 11: "orange", 12: "orange", 18: "yellow" },
        ranges: [
          { start: 16, end: 17, color: "orange" },
          { start: 21, end: 25, color: "pink" }
        ],
        events: [
          ["4", "Fri", "teal", "St. Nicholas Day; Community Potluck"],
          ["8", "Tue", "blue", "Community Council Meeting, 8:30 AM"],
          ["11", "Fri", "orange", "Santa Lucia"],
          ["12", "Sat", "orange", "Winter Faire"],
          ["16-17", "Wed-Thu", "orange", "Advent Spiral Walk"],
          ["16", "Wed", "purple", "Board Meeting, 6:30 PM"],
          ["18", "Fri", "yellow", "Early Release (Noon)"],
          ["21-25", "Mon-Fri", "pink", "Winter Break (No School)"]
        ]
      },
      {
        title: "JANUARY 2027", year: 2027, month: 0, theme: "teal",
        marks: { 1: "red", 4: "orange", 8: "teal", 12: "blue", 18: "red", 20: "purple", 27: "orange" },
        ranges: [],
        events: [
          ["1", "Fri", "red", "Winter Break (No School)"],
