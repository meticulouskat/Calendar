
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>2026-2027 Community Calendar</title>
  <style>
    :root {
      --navy: #062b63;
      --blue: #0768bb;
      --teal: #168f92;
      --green: #386c3b;
      --purple: #5a438f;
      --red: #d91f26;
      --pink: #ff858f;
      --yellow: #ffc928;
      --orange: #f26618;
      --ink: #06133a;
      --line: #c8d0dc;
      --paper: #fffefa;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at calc(50% - 430px) 5%, rgba(255, 232, 151, 0.18), transparent 26%),
        radial-gradient(circle at calc(50% + 390px) 10%, rgba(70, 146, 111, 0.12), transparent 27%),
        var(--paper);
      color: var(--ink);
      font-family: Arial, Helvetica, sans-serif;
    }

    .community-calendar {
      width: min(1120px, 100%);
      margin: 0 auto;
      padding: 12px 18px 26px;
      background: transparent;
    }

    .calendar-header {
      display: block;
      width: 100%;
      margin: 0 0 8px;
      text-align: center;
    }

    .title-block {
      width: 100%;
    }

    .title-block h1 {
      margin: 0;
      color: var(--navy);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(34px, 6vw, 58px);
      line-height: 0.95;
      letter-spacing: 0;
      font-weight: 800;
      white-space: nowrap;
    }

    .title-block p {
      margin: 3px 0 0;
      color: var(--navy);
      font-size: clamp(19px, 3vw, 32px);
      line-height: 1;
      font-weight: 800;
      letter-spacing: 2px;
    }

    .months-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .month-card,
    .key-card {
      container-type: inline-size;
      overflow: hidden;
      min-height: 352px;
      border: 1.8px solid var(--theme, var(--navy));
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 1px 0 rgba(7, 30, 70, 0.06);
    }

    .month-title,
    .key-title {
      padding: 4px 8px 5px;
      color: #fff;
      background: var(--theme, var(--navy));
      text-align: center;
      font-size: 19px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: 1px;
    }

    .month-body {
      padding: 8px 10px 10px;
    }

    .calendar-grid {
      position: relative;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      grid-template-rows: 20px repeat(6, 25px);
      gap: 0;
      margin: 0 3px 6px;
      user-select: none;
    }

    .weekday {
      align-self: center;
      text-align: center;
      color: #000;
      font-size: 14px;
      line-height: 1;
      font-weight: 800;
    }

    .day-cell {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      min-width: 0;
      color: #000;
      font-size: 15px;
      line-height: 1;
      font-weight: 800;
    }

    .day-num {
      position: relative;
      z-index: 3;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 25px;
      height: 25px;
      border-radius: 999px;
    }

    .day-num.marked {
      color: #fff;
    }

    .day-num.yellow,
    .day-num.pink {
      color: #06133a;
    }

    .day-num.on-dark-range {
      color: #fff;
    }

    .range-strip {
      position: relative;
      z-index: 1;
      align-self: center;
      height: 20px;
      margin: 0 2px;
      border-radius: 999px;
      opacity: 0.95;
    }

    .red { background: var(--red); }
    .pink { background: var(--pink); }
    .purple { background: var(--purple); }
    .blue { background: var(--blue); }
    .teal { background: var(--teal); }
    .green { background: var(--green); }
    .yellow { background: var(--yellow); }
    .orange { background: var(--orange); }

    .events-list {
      display: grid;
      gap: 5px;
      margin-top: 5px;
      padding: 0 2px;
    }

    .event-row {
      display: grid;
      grid-template-columns: 48px 58px minmax(0, 1fr);
      align-items: start;
      column-gap: 8px;
      row-gap: 1px;
      color: #000;
      font-size: 12.8px;
      line-height: 1.25;
      font-weight: 700;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      height: 22px;
      padding: 0 5px;
      border-radius: 999px;
      color: #fff;
      font-size: 13px;
      font-weight: 900;
      line-height: 1;
      white-space: nowrap;
    }

    .badge.yellow,
    .badge.pink {
      color: #06133a;
    }

    .dow {
      color: #000;
      font-size: 12px;
      line-height: 1.25;
      font-weight: 800;
      white-space: nowrap;
    }

    .event-text {
      min-width: 0;
    }

    @container (max-width: 340px) {
      .event-row {
        grid-template-columns: 48px 58px;
      }

      .event-text {
        grid-column: 2 / -1;
      }
    }

    .key-body {
      padding: 18px 30px 22px;
    }

    .key-list {
      display: grid;
      gap: 12px;
      margin-bottom: 28px;
    }

    .key-item {
      display: grid;
      grid-template-columns: 28px 1fr;
      align-items: center;
      gap: 10px;
      color: var(--ink);
      font-size: 14px;
      line-height: 1.2;
      font-weight: 700;
    }

    .key-dot {
      width: 20px;
      height: 20px;
      border-radius: 50%;
    }

    .note {
      display: grid;
      grid-template-columns: 48px 1fr;
      align-items: center;
      gap: 16px;
      border-top: 1px solid #8ba2c1;
      padding: 16px 8px 0;
      color: var(--ink);
      font-size: 15px;
      line-height: 1.35;
      font-weight: 700;
    }

    .star {
      color: #174a91;
      font-size: 43px;
      line-height: 1;
    }

    @media (max-width: 980px) {
      .community-calendar {
        padding-inline: 12px;
      }

      .months-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .title-block h1 {
        white-space: normal;
      }
    }

    @media (max-width: 650px) {
      .months-grid {
        grid-template-columns: 1fr;
      }

      .month-card,
      .key-card {
        min-height: auto;
      }
    }

    @media print {
      body {
        background: #fff;
      }

      .community-calendar {
        width: 11in;
        padding: 0.15in;
      }

      .months-grid {
        gap: 0.14in;
      }

      .month-card,
      .key-card {
        break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <main class="community-calendar" aria-label="2026-2027 Community Calendar">
    <header class="calendar-header">
      <div class="title-block">
        <h1>2026-2027 COMMUNITY CALENDAR</h1>
        <p>Events at a Glance</p>
      </div>
    </header>

    <section class="months-grid" id="calendarMonths"></section>
  </main>

  <script>
